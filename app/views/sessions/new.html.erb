<main class="public-page">
  <div class="form-shell">
    <h1><%= t('.title') %></h1>
    <%= tag.div(flash[:alert], style: "color:red") if flash[:alert] %>
    <%= tag.div(flash[:notice], style: "color:green") if flash[:notice] %>

    <%= form_with url: session_path, class: "section form-stack", style: "margin-top: var(--space-5)" do |form| %>
      <div>
        <%= form.label :email_address, class: "field-label" %>
        <%= form.email_field :email_address,
              autofocus: true,
              autocomplete: "username",
              class: "field-control" %>
      </div>

      <div>
        <%= form.label :password, class: "field-label" %>
        <%= form.password_field :password,
              autocomplete: "current-password",
              maxlength: 72,
              class: "field-control" %>
      </div>

      <%= form.submit t('.login'), class: "btn btn-primary" %>

      <p class="small">
        <%= link_to t('.password_forget'), new_password_path %>
      </p>
    <% end %>
  </div>
</main>
