<%= turbo_frame_tag "study-form" do %>
  <%= form_with model: @study_record, url: study_records_path do |form| %>
    <% if @study_record.errors[:user_id].any? %>
      <p class="group-error">
        すでに学習中の記録があります
      </p>
    <% end %>

    <fieldset>
      <legend class="field-label">時間を選ぶ</legend>
      <% if @study_record.errors[:planned_minutes].any? %>
        <p class="group-error">
          <%= @study_record.errors.full_messages_for(:planned_minutes).first %>
        </p>
      <% end %>

      <div class="segments">
        <% StudyRecord::ALLOWED_PLANNED_MINUTES.each do |minutes| %>
          <%= form.radio_button :planned_minutes, minutes, class: "segment-input" %>
          <%= form.label :planned_minutes, value: minutes, class: "segment-label" do %>
            <span class="num"><%= minutes %></span>分
          <% end %>
        <% end %>
      </div>
    </fieldset>

    <div>
      <%= form.label :activity %>
      <%= form.text_field :activity %>
      <% if @study_record.errors[:activity].any? %>
        <p class="group-error">
          <%= @study_record.errors.full_messages_for(:activity).first %>
        </p>
      <% end %>
    </div>

    <%= form.submit "学習を開始する" %>
  <% end %>
<% end %>
